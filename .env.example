# Claude Docker — Environment Configuration
# Copy this file to .env and edit values.

# ==== Required ====
PROJECT_DIR=/absolute/path/to/your/project

# ==== Claude Code Version (optional) ====
# Omit or set to empty for latest
# CLAUDE_CODE_VERSION=1.2.3

# ==== Path B: Console API Keys (optional) ====
# Required only if using API key authentication (not OAuth)
# CLAUDE_API_KEY_A=sk-ant-...
# CLAUDE_API_KEY_B=sk-ant-...

# ==== Linux: UID/GID (auto-set by install.sh) ====
# UID=1000
# GID=1000

# ==== Tier B: Git Worktree Paths (set by setup-worktrees.sh) ====
# PROJECT_DIR_A=/path/to/worktree-a
# PROJECT_DIR_B=/path/to/worktree-b
