#!/usr/bin/env bash
# claude-docker — multi-account CLI wrapper
# Run multiple Claude Code instances with independent accounts.
#
# Usage:  scripts/claude-docker <command> [args...]
#
# Commands:
#   up/down/restart   Manage containers
#   claude [svc]      Start Claude Code (default: claude-a)
#   auth [svc]        Inject OAuth credentials from macOS Keychain
#   exec <svc>        Open shell in a service
#   usage [type]      Token usage report
#   build             Build/rebuild Docker image
#   config/compose    Advanced compose operations
#   help              Show help
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- Colors -------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

log_info()  { echo -e "${CYAN}[INFO]${NC} $1"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# --- Compose Command Builder --------------------------------------------------

# Detect which overlay files are active by checking:
# 1. Which compose files exist on disk
# 2. Platform detection for linux override
# 3. .env hints for worktree
build_compose_cmd() {
    local cmd="docker compose"
    local project_root="$PROJECT_ROOT"

    # Base compose (always required)
    cmd+=" -f ${project_root}/docker-compose.yml"

    # Linux override: auto-detect platform
    if [[ "$(uname -s)" == "Linux" ]] && [[ -f "${project_root}/docker-compose.linux.yml" ]]; then
        cmd+=" -f ${project_root}/docker-compose.linux.yml"
        # Export UID/GID for linux override
        export UID=$(id -u) GID=$(id -g)
    fi

    # Worktree override: check if PROJECT_DIR_A is set in .env
    if [[ -f "${project_root}/.env" ]]; then
        local pdir_a
        pdir_a=$(grep -E '^PROJECT_DIR_A=' "${project_root}/.env" 2>/dev/null | cut -d'=' -f2- || true)
        if [[ -n "$pdir_a" ]] && [[ -f "${project_root}/docker-compose.worktree.yml" ]]; then
            cmd+=" -f ${project_root}/docker-compose.worktree.yml"
        fi
    fi

    echo "$cmd"
}

# Cache the compose command for the session
COMPOSE_CMD=""
get_compose_cmd() {
    if [[ -z "$COMPOSE_CMD" ]]; then
        COMPOSE_CMD=$(build_compose_cmd)
    fi
    echo "$COMPOSE_CMD"
}

# Determine the primary interactive service
get_primary_service() {
    echo "claude-a"
}

# --- Config Dir Path Builder ---------------------------------------------------

# List account state directories under ~/.claude-state/account-*.
# Outputs one path per line.
list_account_dirs() {
    local state_base="$HOME/.claude-state"
    [[ -d "$state_base" ]] || return
    for dir in "$state_base"/account-*; do
        [[ -d "$dir" ]] || continue
        echo "$dir"
    done
}

# Build a temporary merged directory for ccusage.
# ccusage expects CLAUDE_CONFIG_DIR/projects/<hash>/*.jsonl.
# Since it does not support multiple directories, we symlink each
# account's project subdirectories into a single temporary tree.
# Also includes the host's ~/.claude/projects if present.
# Prints the temp dir path; caller is responsible for cleanup.
build_merged_config_dir() {
    local tmpdir
    tmpdir=$(mktemp -d)
    mkdir -p "$tmpdir/projects"

    # Merge container account projects
    while IFS= read -r acct_dir; do
        [[ -d "$acct_dir/projects" ]] || continue
        local acct_name
        acct_name=$(basename "$acct_dir")
        for proj in "$acct_dir/projects"/*/; do
            [[ -d "$proj" ]] || continue
            local proj_name
            proj_name=$(basename "$proj")
            ln -sf "$proj" "$tmpdir/projects/${acct_name}_${proj_name}"
        done
    done < <(list_account_dirs)

    echo "$tmpdir"
}

# --- Subcommands --------------------------------------------------------------

cmd_up() {
    local cmd
    cmd=$(get_compose_cmd)
    echo -e "${CYAN}Starting containers...${NC}"
    echo -e "${DIM}  $cmd up -d${NC}"
    eval "$cmd up -d" "$@"
    echo -e "${GREEN}Containers started.${NC}"
    echo ""
    eval "$cmd ps"
}

cmd_down() {
    local cmd
    cmd=$(get_compose_cmd)
    echo -e "${CYAN}Stopping containers...${NC}"
    eval "$cmd down" "$@"
    echo -e "${GREEN}Containers stopped.${NC}"
}

cmd_restart() {
    local cmd
    cmd=$(get_compose_cmd)
    echo -e "${CYAN}Restarting containers...${NC}"
    eval "$cmd restart" "$@"
    echo -e "${GREEN}Containers restarted.${NC}"
}

cmd_logs() {
    local cmd
    cmd=$(get_compose_cmd)
    eval "$cmd logs -f" "$@"
}

cmd_ps() {
    local cmd
    cmd=$(get_compose_cmd)
    eval "$cmd ps" "$@"
}

cmd_exec() {
    local service="${1:?Usage: claude-docker exec <service> [command...]}"
    shift
    local cmd
    cmd=$(get_compose_cmd)
    if [[ $# -eq 0 ]]; then
        eval "$cmd exec $service bash"
    else
        eval "$cmd exec $service" "$@"
    fi
}

cmd_claude() {
    local service="${1:-$(get_primary_service)}"
    local cmd
    cmd=$(get_compose_cmd)
    echo -e "${CYAN}Starting Claude Code in ${BOLD}$service${NC}${CYAN}...${NC}"
    eval "$cmd exec $service claude"
}

# Resolve a compose service name to its running Docker container ID.
get_container_id() {
    local svc="$1"
    eval "$(get_compose_cmd) ps -q $svc 2>/dev/null"
}

# Extract OAuth credentials from macOS Keychain (host-side).
# Returns JSON string or empty on failure.
get_keychain_credentials() {
    if [[ "$(uname -s)" != "Darwin" ]]; then
        return 1
    fi
    security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null
}

# Inject credentials JSON into a container's state directory on the host.
inject_credentials() {
    local svc="$1"
    local creds="$2"

    # Map service name to host state directory
    local state_dir
    case "$svc" in
        claude-a)  state_dir="$HOME/.claude-state/account-a" ;;
        claude-b)  state_dir="$HOME/.claude-state/account-b" ;;
        *)         state_dir="$HOME/.claude-state/account-${svc}" ;;
    esac

    if [[ ! -d "$state_dir" ]]; then
        mkdir -p "$state_dir"
        chmod 700 "$state_dir"
    fi

    echo "$creds" > "$state_dir/.credentials.json"
    chmod 600 "$state_dir/.credentials.json"
}

cmd_auth() {
    local service="${1:-}"
    local cmd
    cmd=$(get_compose_cmd)

    # On macOS, extract credentials from Keychain (host-side auth)
    local creds=""
    creds=$(get_keychain_credentials) || true

    if [[ -z "$creds" ]]; then
        # Not macOS or no credentials in Keychain
        echo -e "${YELLOW}No credentials found in macOS Keychain.${NC}"
        echo -e "Authenticate on the host first, then re-run this command:"
        echo -e "  ${DIM}claude auth login${NC}"
        echo -e ""
        echo -e "Or set API keys in .env (Path B):"
        echo -e "  ${DIM}CLAUDE_API_KEY_A=sk-ant-...${NC}"
        exit 1
    fi

    # Determine which services to authenticate
    local services=()
    if [[ -n "$service" ]]; then
        services=("$service")
    else
        services=("claude-a" "claude-b")
    fi

    echo -e "${BOLD}Injecting credentials from macOS Keychain${NC}"
    echo ""

    for svc in "${services[@]}"; do
        inject_credentials "$svc" "$creds"
        echo -e "  ${GREEN}*${NC} $svc — credentials written"
    done

    echo ""

    # Verify: check auth status in first running container
    local first_svc="${services[0]}"
    local cid
    cid=$(get_container_id "$first_svc")
    if [[ -n "$cid" ]]; then
        echo -e "${DIM}Verifying ($first_svc):${NC}"
        docker exec "$cid" claude auth status 2>&1 || true
    else
        log_info "Containers not running. Credentials will be available on next start."
    fi
}

cmd_build() {
    local cmd
    cmd=$(get_compose_cmd)
    echo -e "${CYAN}Building Docker image...${NC}"
    eval "$cmd build" "$@"
    echo -e "${GREEN}Build complete.${NC}"
}

cmd_config() {
    local cmd
    cmd=$(get_compose_cmd)
    echo -e "${DIM}Compose command: $cmd${NC}"
    echo ""
    eval "$cmd config" "$@"
}

cmd_compose() {
    local cmd
    cmd=$(get_compose_cmd)
    eval "$cmd" "$@"
}

cmd_usage() {
    # Check for npx availability (runs on host, not in container)
    if ! command -v npx &>/dev/null; then
        log_error "npx not found. Node.js is required to run ccusage."
        echo -e "  Install Node.js 20+: ${CYAN}https://nodejs.org/${NC}"
        echo -e "  macOS: ${DIM}brew install node@20${NC}"
        echo -e "  Linux: ${DIM}curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - && sudo apt-get install -y nodejs${NC}"
        exit 1
    fi

    # Parse report type: first positional arg if it matches a known ccusage type
    local report_type="daily"
    local pass_args=()

    if [[ $# -gt 0 ]]; then
        case "$1" in
            daily|monthly|session|blocks|statusline)
                report_type="$1"
                shift
                ;;
        esac
    fi
    pass_args=("$@")

    # Build merged config directory with symlinks from all sources
    local merged_dir
    merged_dir=$(build_merged_config_dir)
    trap "rm -rf '$merged_dir'" EXIT

    # Check if any project data was found
    local project_count
    project_count=$(find "$merged_dir/projects" -mindepth 1 -maxdepth 1 -type l 2>/dev/null | wc -l | tr -d ' ')

    if [[ "$project_count" -eq 0 ]]; then
        rm -rf "$merged_dir"
        log_error "No session data found."
        echo -e "  Run Claude Code in a container first to generate usage data:"
        echo -e "  ${DIM}scripts/claude-docker claude${NC}"
        exit 1
    fi

    # Display aggregation header
    echo -e "${BOLD}Token Usage Report${NC}"
    echo -e "${DIM}Report type: $report_type${NC}"
    echo -e "${DIM}Data sources (${project_count} projects):${NC}"

    while IFS= read -r acct_dir; do
        local acct_name
        acct_name=$(basename "$acct_dir")
        if [[ -d "$acct_dir/projects" ]]; then
            local count
            count=$(find "$acct_dir/projects" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
            [[ "$count" -gt 0 ]] && echo -e "  ${GREEN}*${NC} $acct_name ${DIM}(${count} projects)${NC}"
        fi
    done < <(list_account_dirs)

    echo ""

    # Run ccusage with merged directory
    CLAUDE_CONFIG_DIR="$merged_dir" npx ccusage@latest "$report_type" ${pass_args[@]+"${pass_args[@]}"}
}

cmd_help() {
    local cmd
    cmd=$(get_compose_cmd)

    cat <<HELP

${BOLD}claude-docker${NC} — multi-account CLI wrapper

${BOLD}USAGE${NC}
  scripts/claude-docker <command> [args...]

${BOLD}LIFECYCLE${NC}
  ${GREEN}up${NC}                    Start all containers
  ${GREEN}down${NC}                  Stop all containers
  ${GREEN}restart${NC}               Restart all containers
  ${GREEN}build${NC}                 Build/rebuild Docker image
  ${GREEN}ps${NC}                    Show container status
  ${GREEN}logs${NC}                  Follow container logs

${BOLD}INTERACTIVE${NC}
  ${GREEN}claude${NC} [service]      Start Claude Code (default: claude-a)
  ${GREEN}auth${NC} [service]        Inject OAuth credentials from macOS Keychain
  ${GREEN}exec${NC} <service>        Open shell in a service

${BOLD}USAGE TRACKING${NC}
  ${GREEN}usage${NC} [type] [flags]  Token usage report (default: daily)
                        Types: daily, monthly, session, blocks, statusline
                        Flags: --since, --until, --json, --breakdown, --compact

${BOLD}ADVANCED${NC}
  ${GREEN}config${NC}                Show resolved compose configuration
  ${GREEN}compose${NC} ...           Pass raw args to docker compose

${BOLD}SERVICES${NC}
  claude-a              Account A (default)
  claude-b              Account B

${BOLD}DETECTED COMPOSE COMMAND${NC}
  ${DIM}$cmd${NC}

HELP
}

# --- Main ---------------------------------------------------------------------

main() {
    local command="${1:-help}"
    shift 2>/dev/null || true

    case "$command" in
        up)        cmd_up "$@" ;;
        down)      cmd_down "$@" ;;
        restart)   cmd_restart "$@" ;;
        logs)      cmd_logs "$@" ;;
        ps)        cmd_ps "$@" ;;
        exec)      cmd_exec "$@" ;;
        claude)    cmd_claude "$@" ;;
        auth)      cmd_auth "$@" ;;
        usage)     cmd_usage "$@" ;;
        build)     cmd_build "$@" ;;
        config)    cmd_config "$@" ;;
        compose)   cmd_compose "$@" ;;
        help|--help|-h)  cmd_help ;;
        *)
            echo -e "${RED}Unknown command: $command${NC}" >&2
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
